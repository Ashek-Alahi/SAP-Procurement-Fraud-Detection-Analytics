{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# PHASE 5: Executive Fraud Detection Dashboard\n",
        "\n",
        "**Purpose:** Consolidate all fraud detection analyses from notebooks 01-04 into one comprehensive executive-level visualization dashboard.\n",
        "\n",
        "**Scope:** This dashboard combines duplicate invoice detection, split purchase detection, abnormal vendor detection, and approval bypass detection with prioritized SAP recommendations.\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Import libraries and configure dashboard"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from pathlib import Path\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as mpatches\n",
        "from matplotlib.patches import Rectangle\n",
        "import seaborn as sns\n",
        "import plotly.graph_objects as go\n",
        "import plotly.express as px\n",
        "from plotly.subplots import make_subplots\n",
        "\n",
        "# Configure display and styling\n",
        "sns.set_theme(style=\"whitegrid\", palette=\"husl\")\n",
        "pd.options.display.float_format = \"{:,.0f}\".format\n",
        "plt.rcParams['figure.figsize'] = (16, 10)\n",
        "plt.rcParams['font.size'] = 10\n",
        "\n",
        "PROJECT_ROOT = Path.cwd()\n",
        "if not (PROJECT_ROOT / \"03_Data\").exists():\n",
        "    PROJECT_ROOT = PROJECT_ROOT.parent\n",
        "\n",
        "DATA_DIR = PROJECT_ROOT / \"03_Data\"\n",
        "ANALYSIS_DIR = PROJECT_ROOT / \"05_Python_Analysis\" / \"outputs\"\n",
        "OUTPUT_DIR = PROJECT_ROOT / \"06_Visualizations\" / \"outputs\"\n",
        "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "print(f\"✓ Project root: {PROJECT_ROOT}\")\n",
        "print(f\"✓ Data directory: {DATA_DIR}\")\n",
        "print(f\"✓ Analysis directory: {ANALYSIS_DIR}\")\n",
        "print(f\"✓ Output directory: {OUTPUT_DIR}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Load all fraud analysis results"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Load raw data\n",
        "vendors = pd.read_csv(DATA_DIR / \"vendors.csv\", parse_dates=[\"registration_date\"])\n",
        "invoices = pd.read_csv(DATA_DIR / \"invoices.csv\", parse_dates=[\"invoice_date\", \"posting_date\", \"payment_date\"])\n",
        "purchase_orders = pd.read_csv(DATA_DIR / \"purchase_orders.csv\", parse_dates=[\"po_date\", \"approval_date\"])\n",
        "\n",
        "# Load analysis outputs\n",
        "duplicate_suspects = pd.read_csv(ANALYSIS_DIR / \"duplicate_invoice_suspects.csv\")\n",
        "duplicate_vendor_summary = pd.read_csv(ANALYSIS_DIR / \"duplicate_invoice_vendor_summary.csv\")\n",
        "\n",
        "split_details = pd.read_csv(ANALYSIS_DIR / \"split_purchase_details.csv\")\n",
        "split_clusters = pd.read_csv(ANALYSIS_DIR / \"split_purchase_clusters.csv\")\n",
        "split_risk_scorecard = pd.read_csv(ANALYSIS_DIR / \"split_purchase_risk_scorecard.csv\")\n",
        "\n",
        "abnormal_vendor_scorecard = pd.read_csv(ANALYSIS_DIR / \"abnormal_vendor_risk_scorecard.csv\")\n",
        "ghost_vendor_candidates = pd.read_csv(ANALYSIS_DIR / \"ghost_vendor_candidates.csv\")\n",
        "\n",
        "approval_violations = pd.read_csv(ANALYSIS_DIR / \"approval_bypass_violations.csv\")\n",
        "approval_department_risk = pd.read_csv(ANALYSIS_DIR / \"approval_bypass_department_risk.csv\")\n",
        "approval_employee_ranking = pd.read_csv(ANALYSIS_DIR / \"approval_bypass_employee_ranking.csv\")\n",
        "\n",
        "print(\"\\n✓ All analysis files loaded successfully\")\n",
        "print(f\"  - Duplicate invoice suspects: {len(duplicate_suspects)}\")\n",
        "print(f\"  - Split purchase details: {len(split_details)}\")\n",
        "print(f\"  - Abnormal vendors: {len(abnormal_vendor_scorecard)}\")\n",
        "print(f\"  - Approval violations: {len(approval_violations)}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Section 1: Executive Summary Scorecard"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Calculate aggregate metrics\n",
        "total_transactions_analyzed = len(invoices) + len(purchase_orders)\n",
        "\n",
        "fraud_suspects_count = (\n",
        "    len(duplicate_suspects) +\n",
        "    len(split_details) +\n",
        "    len(ghost_vendor_candidates) +\n",
        "    len(approval_violations)\n",
        ")\n",
        "\n",
        "total_financial_exposure_jpy = (\n",
        "    duplicate_suspects[\"invoice_amount\"].sum() +\n",
        "    split_details[\"total_amount\"].sum() +\n",
        "    ghost_vendor_candidates[\"total_invoice_value_jpy\"].sum() +\n",
        "    approval_violations[\"total_amount\"].sum()\n",
        ")\n",
        "\n",
        "fraud_rate_pct = (fraud_suspects_count / total_transactions_analyzed) * 100 if total_transactions_analyzed > 0 else 0\n",
        "\n",
        "# Create summary dataframe\n",
        "summary_metrics = pd.DataFrame({\n",
        "    \"metric\": [\n",
        "        \"Total Transactions Analyzed\",\n",
        "        \"Total Fraud Suspects Found\",\n",
        "        \"Total Financial Exposure (JPY)\",\n",
        "        \"Fraud Rate (%)\"\n",
        "    ],\n",
        "    \"value\": [\n",
        "        f\"{total_transactions_analyzed:,}\",\n",
        "        f\"{fraud_suspects_count:,}\",\n",
        "        f\"¥{total_financial_exposure_jpy:,.0f}\",\n",
        "        f\"{fraud_rate_pct:.2f}%\"\n",
        "    ],\n",
        "    \"risk_level\": [\"Info\", \"🔴 Critical\", \"🔴 Critical\", \"🔴 Critical\"]\n",
        "})\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"EXECUTIVE SUMMARY - FRAUD DETECTION OVERVIEW\")\n",
        "print(\"=\"*80)\n",
        "print(summary_metrics.to_string(index=False))\n",
        "print(\"=\"*80)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Create Plotly Executive Summary Scorecard\n",
        "fig = make_subplots(\n",
        "    rows=2, cols=2,\n",
        "    subplot_titles=(\n",
        "        \"Total Transactions Analyzed\",\n",
        "        \"Fraud Suspects Detected\",\n",
        "        \"Total Financial Exposure (JPY)\",\n",
        "        \"Overall Fraud Rate (%)\"\n",
        "    ),\n",
        "    specs=[[{\"type\": \"indicator\"}, {\"type\": \"indicator\"}],\n",
        "           [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}]]\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Indicator(\n",
        "        mode=\"number\",\n",
        "        value=total_transactions_analyzed,\n",
        "        title={\"text\": \"Transactions\"},\n",
        "        number={\"font\": {\"size\": 40, \"color\": \"#1f77b4\"}},\n",
        "    ),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Indicator(\n",
        "        mode=\"number\",\n",
        "        value=fraud_suspects_count,\n",
        "        title={\"text\": \"Suspects\"},\n",
        "        number={\"font\": {\"size\": 40, \"color\": \"#d62728\"}},\n",
        "    ),\n",
        "    row=1, col=2\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Indicator(\n",
        "        mode=\"number\",\n",
        "        value=total_financial_exposure_jpy,\n",
        "        title={\"text\": \"Exposure (JPY)\"},\n",
        "        number={\"font\": {\"size\": 40, \"color\": \"#ff7f0e\"}, \"prefix\": \"¥\"},\n",
        "    ),\n",
        "    row=2, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Indicator(\n",
        "        mode=\"number\",\n",
        "        value=fraud_rate_pct,\n",
        "        title={\"text\": \"Fraud Rate\"},\n",
        "        number={\"font\": {\"size\": 40, \"color\": \"#d62728\"}, \"suffix\": \"%\"},\n",
        "    ),\n",
        "    row=2, col=2\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    title_text=\"<b>EXECUTIVE FRAUD DETECTION DASHBOARD</b><br><sub>SAP Procurement Fraud Detection Analytics</sub>\",\n",
        "    height=500,\n",
        "    showlegend=False,\n",
        "    font=dict(size=12)\n",
        ")\n",
        "\n",
        "fig.write_html(OUTPUT_DIR / \"01_executive_summary_scorecard.html\")\n",
        "fig.show()\n",
        "print(\"✓ Executive Summary Scorecard saved\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Section 2: Fraud by Category Analysis"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Create fraud category summary\n",
        "fraud_categories = pd.DataFrame({\n",
        "    \"fraud_type\": [\n",
        "        \"Duplicate Invoices\",\n",
        "        \"Split Purchases\",\n",
        "        \"Abnormal Vendors\",\n",
        "        \"Approval Bypasses\"\n",
        "    ],\n",
        "    \"count\": [\n",
        "        len(duplicate_suspects),\n",
        "        len(split_details),\n",
        "        len(ghost_vendor_candidates),\n",
        "        len(approval_violations)\n",
        "    ],\n",
        "    \"total_value_jpy\": [\n",
        "        duplicate_suspects[\"invoice_amount\"].sum(),\n",
        "        split_details[\"total_amount\"].sum(),\n",
        "        ghost_vendor_candidates[\"total_invoice_value_jpy\"].sum(),\n",
        "        approval_violations[\"total_amount\"].sum()\n",
        "    ],\n",
        "    \"risk_color\": [\"#ff6b6b\", \"#ff8c42\", \"#ffd93d\", \"#6bcf7f\"]\n",
        "})\n",
        "\n",
        "fraud_categories[\"avg_value_jpy\"] = fraud_categories[\"total_value_jpy\"] / fraud_categories[\"count\"]\n",
        "\n",
        "print(\"\\nFRAUD CATEGORY BREAKDOWN:\")\n",
        "print(fraud_categories.to_string(index=False))\n",
        "\n",
        "# Create Plotly visualization\n",
        "fig = make_subplots(\n",
        "    rows=1, cols=2,\n",
        "    subplot_titles=(\"Fraud Count by Category\", \"Financial Exposure by Category\"),\n",
        "    specs=[[{\"type\": \"bar\"}, {\"type\": \"pie\"}]]\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Bar(\n",
        "        x=fraud_categories[\"fraud_type\"],\n",
        "        y=fraud_categories[\"count\"],\n",
        "        marker_color=fraud_categories[\"risk_color\"],\n",
        "        text=fraud_categories[\"count\"],\n",
        "        textposition=\"outside\",\n",
        "        name=\"Count\",\n",
        "        hovertemplate=\"<b>%{x}</b><br>Suspects: %{y}<extra></extra>\"\n",
        "    ),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Pie(\n",
        "        labels=fraud_categories[\"fraud_type\"],\n",
        "        values=fraud_categories[\"total_value_jpy\"],\n",
        "        marker=dict(colors=fraud_categories[\"risk_color\"]),\n",
        "        hovertemplate=\"<b>%{label}</b><br>Exposure: ¥%{value:,.0f}<extra></extra>\"\n",
        "    ),\n",
        "    row=1, col=2\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    title_text=\"<b>Fraud Detection by Category</b>\",\n",
        "    height=500,\n",
        "    showlegend=True,\n",
        "    font=dict(size=11)\n",
        ")\n",
        "\n",
        "fig.update_xaxes(title_text=\"Fraud Type\", row=1, col=1)\n",
        "fig.update_yaxes(title_text=\"Count of Suspects\", row=1, col=1)\n",
        "\n",
        "fig.write_html(OUTPUT_DIR / \"02_fraud_by_category.html\")\n",
        "fig.show()\n",
        "print(\"✓ Fraud by Category chart saved\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Create detailed comparison chart\n",
        "fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n",
        "fig.suptitle(\"FRAUD CATEGORY DETAILED COMPARISON\", fontsize=16, fontweight='bold', y=0.995)\n",
        "\n",
        "# 1. Count vs Value scatter\n",
        "ax = axes[0, 0]\n",
        "scatter = ax.scatter(\n",
        "    fraud_categories[\"count\"],\n",
        "    fraud_categories[\"total_value_jpy\"],\n",
        "    s=500,\n",
        "    c=range(len(fraud_categories)),\n",
        "    cmap=\"RdYlGn_r\",\n",
        "    alpha=0.7,\n",
        "    edgecolors='black',\n",
        "    linewidth=2\n",
        ")\n",
        "for idx, row in fraud_categories.iterrows():\n",
        "    ax.annotate(row[\"fraud_type\"], (row[\"count\"], row[\"total_value_jpy\"]),\n",
        "                fontsize=9, ha='center', va='center', fontweight='bold')\n",
        "ax.set_xlabel(\"Number of Suspects\", fontsize=11, fontweight='bold')\n",
        "ax.set_ylabel(\"Financial Exposure (JPY)\", fontsize=11, fontweight='bold')\n",
        "ax.set_title(\"Count vs Exposure Analysis\", fontsize=12, fontweight='bold')\n",
        "ax.grid(True, alpha=0.3)\n",
        "\n",
        "# 2. Average value per suspect\n",
        "ax = axes[0, 1]\n",
        "colors = fraud_categories[\"risk_color\"]\n",
        "bars = ax.barh(fraud_categories[\"fraud_type\"], fraud_categories[\"avg_value_jpy\"], color=colors, edgecolor='black', linewidth=1.5)\n",
        "ax.set_xlabel(\"Average Value per Suspect (JPY)\", fontsize=11, fontweight='bold')\n",
        "ax.set_title(\"Average Fraud Value\", fontsize=12, fontweight='bold')\n",
        "for i, (bar, val) in enumerate(zip(bars, fraud_categories[\"avg_value_jpy\"])):\n",
        "    ax.text(val, i, f\" ¥{val:,.0f}\", va='center', fontsize=10, fontweight='bold')\n",
        "\n",
        "# 3. Total exposure breakdown\n",
        "ax = axes[1, 0]\n",
        "wedges, texts, autotexts = ax.pie(\n",
        "    fraud_categories[\"total_value_jpy\"],\n",
        "    labels=fraud_categories[\"fraud_type\"],\n",
        "    autopct='%1.1f%%',\n",
        "    colors=colors,\n",
        "    startangle=90,\n",
        "    textprops={'fontsize': 10, 'fontweight': 'bold'}\n",
        ")\n",
        "for autotext in autotexts:\n",
        "    autotext.set_color('white')\n",
        "    autotext.set_fontweight('bold')\n",
        "ax.set_title(\"Total Exposure Distribution\", fontsize=12, fontweight='bold')\n",
        "\n",
        "# 4. Summary table\n",
        "ax = axes[1, 1]\n",
        "ax.axis('tight')\n",
        "ax.axis('off')\n",
        "\n",
        "table_data = []\n",
        "for idx, row in fraud_categories.iterrows():\n",
        "    table_data.append([\n",
        "        row[\"fraud_type\"],\n",
        "        f\"{row['count']}\",\n",
        "        f\"¥{row['total_value_jpy']:,.0f}\",\n",
        "        f\"¥{row['avg_value_jpy']:,.0f}\"\n",
        "    ])\n",
        "\n",
        "table = ax.table(\n",
        "    cellText=table_data,\n",
        "    colLabels=[\"Fraud Type\", \"Count\", \"Total Value\", \"Average Value\"],\n",
        "    cellLoc='center',\n",
        "    loc='center',\n",
        "    colWidths=[0.25, 0.15, 0.3, 0.3]\n",
        ")\n",
        "table.auto_set_font_size(False)\n",
        "table.set_fontsize(10)\n",
        "table.scale(1, 2.5)\n",
        "\n",
        "# Color header\n",
        "for i in range(4):\n",
        "    table[(0, i)].set_facecolor('#4CAF50')\n",
        "    table[(0, i)].set_text_props(weight='bold', color='white')\n",
        "\n",
        "# Alternate row colors\n",
        "for i in range(1, len(table_data) + 1):\n",
        "    for j in range(4):\n",
        "        if i % 2 == 0:\n",
        "            table[(i, j)].set_facecolor('#f0f0f0')\n",
        "        else:\n",
        "            table[(i, j)].set_facecolor('#ffffff')\n",
        "        table[(i, j)].set_edgecolor('black')\n",
        "\n",
        "ax.set_title(\"Summary Statistics\", fontsize=12, fontweight='bold', pad=20)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(OUTPUT_DIR / \"02_fraud_category_detailed.png\", dpi=300, bbox_inches='tight')\n",
        "plt.show()\n",
        "print(\"✓ Fraud Category Detailed Comparison saved\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Section 3: Timeline Analysis - Fraud Patterns Over Time"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Prepare timeline data for each fraud type\n",
        "duplicate_timeline = (\n",
        "    duplicate_suspects.copy()\n",
        "    .assign(month=pd.to_datetime(duplicate_suspects[\"posting_date\"]).dt.to_period(\"M\").dt.to_timestamp())\n",
        "    .groupby(\"month\", as_index=False)\n",
        "    .agg(count=(\"invoice_id\", \"count\"), value=(\"invoice_amount\", \"sum\"))\n",
        "    .rename(columns={\"count\": \"duplicate_count\", \"value\": \"duplicate_value\"})\n",
        ")\n",
        "\n",
        "split_timeline = (\n",
        "    split_details.copy()\n",
        "    .assign(month=pd.to_datetime(split_details[\"po_date\"]).dt.to_period(\"M\").dt.to_timestamp())\n",
        "    .groupby(\"month\", as_index=False)\n",
        "    .agg(count=(\"po_number\", \"count\"), value=(\"total_amount\", \"sum\"))\n",
        "    .rename(columns={\"count\": \"split_count\", \"value\": \"split_value\"})\n",
        ")\n",
        "\n",
        "approval_timeline = (\n",
        "    approval_violations.copy()\n",
        "    .assign(month=pd.to_datetime(approval_violations[\"po_date\"]).dt.to_period(\"M\").dt.to_timestamp())\n",
        "    .groupby(\"month\", as_index=False)\n",
        "    .agg(count=(\"po_number\", \"count\"), value=(\"total_amount\", \"sum\"))\n",
        "    .rename(columns={\"count\": \"approval_count\", \"value\": \"approval_value\"})\n",
        ")\n",
        "\n",
        "# Merge all timelines\n",
        "all_months = pd.concat([duplicate_timeline[\"month\"], split_timeline[\"month\"], approval_timeline[\"month\"]]).drop_duplicates().sort_values()\n",
        "timeline_data = pd.DataFrame({\"month\": all_months})\n",
        "timeline_data = timeline_data.merge(duplicate_timeline, on=\"month\", how=\"left\").fillna(0)\n",
        "timeline_data = timeline_data.merge(split_timeline, on=\"month\", how=\"left\").fillna(0)\n",
        "timeline_data = timeline_data.merge(approval_timeline, on=\"month\", how=\"left\").fillna(0)\n",
        "\n",
        "print(\"\\nTIMELINE DATA:\")\n",
        "print(timeline_data.to_string(index=False))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Create interactive timeline chart\n",
        "fig = make_subplots(\n",
        "    rows=2, cols=1,\n",
        "    subplot_titles=(\"Fraud Count Trends Over Time\", \"Financial Exposure Trends Over Time\"),\n",
        "    shared_xaxes=True,\n",
        "    vertical_spacing=0.15\n",
        ")\n",
        "\n",
        "# Count trends\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=timeline_data[\"month\"],\n",
        "        y=timeline_data[\"duplicate_count\"],\n",
        "        mode=\"lines+markers\",\n",
        "        name=\"Duplicate Invoices\",\n",
        "        line=dict(color=\"#ff6b6b\", width=3),\n",
        "        marker=dict(size=8)\n",
        "    ),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=timeline_data[\"month\"],\n",
        "        y=timeline_data[\"split_count\"],\n",
        "        mode=\"lines+markers\",\n",
        "        name=\"Split Purchases\",\n",
        "        line=dict(color=\"#ff8c42\", width=3),\n",
        "        marker=dict(size=8)\n",
        "    ),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=timeline_data[\"month\"],\n",
        "        y=timeline_data[\"approval_count\"],\n",
        "        mode=\"lines+markers\",\n",
        "        name=\"Approval Bypasses\",\n",
        "        line=dict(color=\"#6bcf7f\", width=3),\n",
        "        marker=dict(size=8)\n",
        "    ),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "# Value trends\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=timeline_data[\"month\"],\n",
        "        y=timeline_data[\"duplicate_value\"],\n",
        "        mode=\"lines+markers\",\n",
        "        name=\"Duplicate Exposure\",\n",
        "        line=dict(color=\"#ff6b6b\", width=3, dash=\"dash\"),\n",
        "        marker=dict(size=8),\n",
        "        showlegend=False\n",
        "    ),\n",
        "    row=2, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=timeline_data[\"month\"],\n",
