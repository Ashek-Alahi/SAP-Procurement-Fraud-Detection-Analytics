        "# Create master dashboard with all key metrics\n",
        "from plotly.subplots import make_subplots\n",
        "import plotly.graph_objects as go\n",
        "\n",
        "fig = make_subplots(\n",
        "    rows=3, cols=3,\n",
        "    subplot_titles=(\n",
        "        \"Total Transactions\", \"Fraud Suspects\", \"Fraud Rate\",\n",
        "        \"Duplicate Invoices\", \"Split Purchases\", \"Ghost Vendors\",\n",
        "        \"Approval Bypasses\", \"Total Exposure\", \"Top Risk Vendor\"\n",
        "    ),\n",
        "    specs=[\n",
        "        [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}, {\"type\": \"indicator\"}],\n",
        "        [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}, {\"type\": \"indicator\"}],\n",
        "        [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}, {\"type\": \"bar\"}]\n",
        "    ],\n",
        "    vertical_spacing=0.15,\n",
        "    horizontal_spacing=0.12\n",
        ")\n",
        "\n",
        "# Row 1: Main metrics\n",
        "fig.add_trace(go.Indicator(mode=\"number\", value=total_transactions_analyzed,\n",
        "                          title=\"Transactions\", number={\"font\": {\"size\": 32, \"color\": \"#1f77b4\"}},\n",
        "                          domain={'x': [0, 0.3], 'y': [0.7, 1]}), row=1, col=1)\n",
        "\n",
        "fig.add_trace(go.Indicator(mode=\"number\", value=fraud_suspects_count,\n",
