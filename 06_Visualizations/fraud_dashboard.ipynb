        "                          domain={'x': [0.33, 0.66], 'y': [0.7, 1]}), row=1, col=2)\n",
        "\n",
        "fig.add_trace(go.Indicator(mode=\"gauge\", value=fraud_rate_pct, title=\"Fraud Rate %\",\n",
